{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-kefu.example.com/schemas/ws/client.json",
  "title": "WS Frame (client ↔ server)",
  "description": "客户端 ↔ 服务端通用帧。客户端用 client_msg_id 保证幂等;服务端用 seq 保证顺序与可恢复。",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "msg.text",
        "msg.image",
        "msg.file",
        "msg.read",
        "msg.recall",
        "msg.chunk",
        "event.typing",
        "event.handoff",
        "event.context",
        "ping",
        "pong",
        "ack",
        "pull",
        "error"
      ]
    },
    "seq": {
      "type": "integer",
      "minimum": 0,
      "description": "服务端发送时填,会话内自增"
    },
    "ack": {
      "type": "integer",
      "minimum": 0,
      "description": "客户端回执已确认到的最大 seq"
    },
    "ts": {
      "type": "integer",
      "description": "epoch ms"
    },
    "session_id": {
      "type": "string",
      "pattern": "^ses_[A-Za-z0-9_-]+$"
    },
    "client_msg_id": {
      "type": "string",
      "maxLength": 64,
      "description": "客户端发送时填,用于幂等"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "msg.text" } }, "required": ["type"] },
      "then": {
        "required": ["session_id", "client_msg_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": { "type": "string", "maxLength": 4000 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "msg.image" } }, "required": ["type"] },
      "then": {
        "required": ["session_id", "client_msg_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "width": { "type": "integer" },
              "height": { "type": "integer" },
              "size": { "type": "integer" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "msg.file" } }, "required": ["type"] },
      "then": {
        "required": ["session_id", "client_msg_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["url", "name", "size"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "name": { "type": "string", "maxLength": 256 },
              "size": { "type": "integer" },
              "mime": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "msg.read" } }, "required": ["type"] },
      "then": {
        "required": ["session_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["up_to_seq"],
            "properties": {
              "up_to_seq": { "type": "integer" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "pull" } }, "required": ["type"] },
      "then": {
        "required": ["session_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["after_seq"],
            "properties": {
              "after_seq": { "type": "integer" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "event.typing" } }, "required": ["type"] },
      "then": {
        "required": ["session_id", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["typing"],
            "properties": { "typing": { "type": "boolean" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "event.context" } }, "required": ["type"] },
      "then": {
        "required": ["session_id", "payload"],
        "properties": {
          "payload": {
            "$ref": "../live-context/live-context.schema.json"
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "error" } }, "required": ["type"] },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
